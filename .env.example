# Kopiera denna fil till .env.local för lokal utveckling, och lägg samma
# variabler under Project Settings → Environment Variables i Vercel för
# produktion.

# OBLIGATORISKT: Supabase — hela datalagret (produkter, ordrar, checkout-
# sessioner, m.m.) ligger här, se supabase/migrations/0001_initial_schema.sql.
# Utan dessa kraschar sajten (Vercels serverless-filsystem är skrivskyddat i
# produktion, så den gamla JSON-fil-baserade lagringen kan inte användas där).
# Hitta värdena i Supabase Dashboard → ditt Garnladan-projekt → Project
# Settings → API:
#   - "Project URL"        → NEXT_PUBLIC_SUPABASE_URL
#   - "anon" / "public"-nyckeln → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - "service_role"-nyckeln (klicka "Reveal") → SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_SERVICE_ROLE_KEY kringgår all radnivåsäkerhet (RLS) — får ALDRIG
# exponeras till klienten eller hamna i ett NEXT_PUBLIC_-fält, bara läsas
# server-side (se lib/supabase.ts).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Lösenord för /admin. Om den saknas faller appen tillbaka på "garn" och
# varnar i konsolen — sätt alltid ett riktigt värde innan driftsättning.
ADMIN_PASSWORD=

# Valfritt: aktiverar riktiga orderbekräftelsemejl via Resend
# (https://resend.com/api-keys). Saknas nyckeln loggas mejlet bara till
# konsolen istället (se lib/email.ts) — bygget och checkout-flödet fungerar
# felfritt utan den.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Garnladan <bestallning@garnladan.se>"

# Valfritt: sajtens fulla URL, används för länkar i bekräftelsemejlet
# (t.ex. till ångerrättssidan) som måste vara absoluta eftersom mejlet
# läses utanför appen. Faller tillbaka på https://garnladan.se om den
# saknas (se lib/email.ts).
NEXT_PUBLIC_SITE_URL=

# Valfritt: aktiverar riktig betalning via Stripe Elements (kort + Klarna).
# Saknas dessa körs det mockade betalflödet automatiskt (se
# components/CheckoutFlow.tsx, lib/stripe.ts) — bygget och checkout-flödet
# fungerar felfritt utan dem. Se README.md "Stripe / betalning" för exakt
# var i Stripe Dashboard varje värde hittas och hur Klarna aktiveras.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Valfritt: aktiverar riktiga fraktsedlar via Fraktjakt (bokning +
# etikett-PDF, se "Skapa fraktsedel" i orderdetaljvyn i admin). Saknas
# dessa visas knappen som inaktiv ("Fraktjakt ej konfigurerat") istället
# för att API-anrop kastar okontrollerade fel — bygget och admin fungerar
# felfritt utan dem (se lib/fraktjakt.ts).
#   1. Logga in på https://api.fraktjakt.se/account/login (eller registrera
#      enligt Fraktjakts manual om kontot inte redan finns).
#   2. Under "Installation"-fliken för integrationen hittar du Consignor ID
#      (heltal) och Consignor Key (sträng) — det är dessa två värden nedan.
#   3. Registrera helst TVÅ separata integrationer i Fraktjakt (en i
#      Testläge, en skarp) och använd testintegrationens värden här tills
#      vi uttryckligen sagt att vi går skarpt — testläge/skarpt läge styrs
#      av VILKET Consignor-par som används, inte av en egen miljövariabel.
#   4. Ett Standardpaket (mått) MÅSTE vara konfigurerat i integrationens
#      inställningar i Fraktjakt — annars misslyckas fraktsökningen (vi
#      skickar bara vikt, inte mått, se lib/fraktjakt.ts).
# shipping_product_id för PostNords tjänster (ombud/hemleverans) är
# kontospecifika och fylls i separat under Inställningar → Fraktjakt i
# admin, inte här.
FRAKTJAKT_CONSIGNOR_ID=
FRAKTJAKT_CONSIGNOR_KEY=

# Krävs för att ladda upp riktiga produktbilder i admin (Vercel Blob).
# Sätts AUTOMATISKT när du kopplar ett Blob-store till projektet i Vercel
# Dashboard → Storage → Create → Blob → Connect Project. Kopiera samma värde
# hit för att uppladdning ska fungera lokalt också (fungerar i vanlig
# `npm run dev`, inget särskilt lokalt Blob-emulator behövs). Se README.md
# "Produktbilder / Vercel Blob" för fullständiga steg. Saknas token visar
# admin ett tydligt felmeddelande vid uppladdningsförsök — resten av sajten
# och bygget fungerar felfritt utan den (SVG-fallbacken visas som idag).
BLOB_READ_WRITE_TOKEN=

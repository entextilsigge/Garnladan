# Kopiera denna fil till .env.local för lokal utveckling, och lägg samma
# variabler under Project Settings → Environment Variables i Vercel för
# produktion.

# Lösenord för /admin. Om den saknas faller appen tillbaka på "garn" och
# varnar i konsolen — sätt alltid ett riktigt värde innan driftsättning.
ADMIN_PASSWORD=

# Valfritt: aktiverar riktiga orderbekräftelsemejl via Resend
# (https://resend.com/api-keys). Saknas nyckeln loggas mejlet bara till
# konsolen istället (se lib/email.ts) — bygget och checkout-flödet fungerar
# felfritt utan den.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Garnladan <bestallning@garnladan.se>"

# Valfritt: sajtens fulla URL, används för länkar i bekräftelsemejlet
# (t.ex. till ångerrättssidan) som måste vara absoluta eftersom mejlet
# läses utanför appen. Faller tillbaka på https://garnladan.se om den
# saknas (se lib/email.ts).
NEXT_PUBLIC_SITE_URL=

# Valfritt: aktiverar riktig betalning via Stripe Elements (kort + Klarna).
# Saknas dessa körs det mockade betalflödet automatiskt (se
# components/CheckoutFlow.tsx, lib/stripe.ts) — bygget och checkout-flödet
# fungerar felfritt utan dem. Se README.md "Stripe / betalning" för exakt
# var i Stripe Dashboard varje värde hittas och hur Klarna aktiveras.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
